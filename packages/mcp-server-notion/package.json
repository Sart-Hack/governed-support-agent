{
  "name": "@gsa/mcp-server-notion",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "mcp-server-notion": "./dist/start.js"
  },
  "files": ["dist"],
  "scripts": {
    "dev": "tsx bin/start.ts",
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "start": "node dist/start.js",
    "clean": "rm -rf dist .turbo node_modules"
  },
  "devDependencies": {
    "@types/node": "22.10.5",
    "tsup": "8.3.5",
    "tsx": "4.19.2",
    "typescript": "5.7.2",
    "vitest": "2.1.8"
  },
  "dependencies": {
    "@gsa/fixtures": "workspace:*",
    "@gsa/mcp-server-base": "workspace:*",
    "zod": "^3.23.8"
  }
}
