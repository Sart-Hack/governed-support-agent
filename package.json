{
  "name": "governed-support-agent",
  "version": "0.0.0",
  "private": true,
  "description": "Governed Support Ops Agent + @sarthak/agent-shield (governance layer)",
  "license": "Apache-2.0",
  "type": "module",
  "engines": {
    "node": ">=22",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "demo": "pnpm --filter @gsa/agent demo",
    "stack:up": "docker compose up -d",
    "stack:down": "docker compose down",
    "stack:wipe": "docker compose down -v",
    "stack:verify": "bash scripts/verify-docker.sh",
    "stack:bootstrap": "node scripts/bootstrap-bifrost.mjs",
    "stack:logs": "docker compose logs -f",
    "mcp:servers": "concurrently -n zendesk,notion,hubspot -c blue,magenta,cyan \"pnpm --filter @gsa/mcp-server-zendesk dev\" \"pnpm --filter @gsa/mcp-server-notion dev\" \"pnpm --filter @gsa/mcp-server-hubspot dev\"",
    "clean": "turbo run clean && rm -rf node_modules .turbo"
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "concurrently": "9.1.2",
    "turbo": "2.3.3",
    "typescript": "5.7.2",
    "vitest": "2.1.8"
  }
}
